{
  "name": "remote-ops-engine",
  "version": "0.1.0",
  "description": "Proactive operations and profitability alerting engine for Remote Coffee",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "run:shadow": "ALERT_MODE=shadow tsx src/index.ts",
    "run:live": "ALERT_MODE=live tsx src/index.ts",
    "run:backtest": "tsx src/backtest.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "croner": "^8.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
